{
  "version": 3,
  "configurePresets": [
    {
      "name": "local-dev",
      "displayName": "Local Development (E:\\DSP-GPU\\)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "ci",
      "displayName": "CI Build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    { "name": "local-dev", "configurePreset": "local-dev" },
    { "name": "ci",        "configurePreset": "ci" }
  ]
}
